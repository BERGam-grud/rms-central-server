async function loadChartHistory(){
  const hours=parseInt(document.getElementById('chart-hours')?.value||'2');
  for(const p of CH_PARAMS){
    const data=await api(`/api/measurements/chart-init?parameter=${p}&hours=${hours}`);
    if(!data||!data.length) continue;
    const ch=chartInst[p]; if(!ch) continue;
    ch.data.labels=data.map(r=>new Date(r.recorded_at).toLocaleTimeString('uk-UA'));
    ch.data.datasets[0].data=data.map(r=>parseFloat(r.value));
    ch.update('none');
    // Заповнюємо chartHist для подальших live оновлень
    const key=data[0].device_id+'::'+p;
    chartHist[key]=data.map(r=>({t:new Date(r.recorded_at),v:parseFloat(r.value)}));
    // Обрізаємо до MAX_PTS
    if(chartHist[key].length>MAX_PTS) chartHist[key]=chartHist[key].slice(-MAX_PTS);
  }
}

function buildChartCards(){
  const grid=document.getElementById('charts-grid'); grid.innerHTML='';
