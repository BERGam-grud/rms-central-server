      </div>
      <div class="post-card-meta">${p.location||'—'} · ${p.region||'—'}</div>
      ${p.latitude?`<div class="post-card-meta" style="font-family:var(--font-mono);font-size:10px;margin-top:2px">${p.latitude}, ${p.longitude}</div>`:''}
      <div class="post-stats" id="ps-stats-${p.id}"><span class="post-stat ps-ok">Завантаження...</span></div>
      ${me.role==='admin'?`<div style="display:flex;gap:6px;margin-top:8px">
        <button class="btn-sm" onclick="event.stopPropagation();openDevModal('${p.id}','','','','',0)">+ Прилад</button>
        <button class="btn-sm" onclick="event.stopPropagation();openPostModal('${p.id}','${p.name}','${(p.location||'').replace(/'/g,'`')}','${p.region||''}',${p.latitude||''},${p.longitude||''})">Редагувати</button>
        <button class="btn-sm red" onclick="event.stopPropagation();deletePost('${p.id}','${p.name}')">Видалити</button>
      </div>`:''}
    </div>`).join('');
  for(const p of posts) loadPostStats(p.id);
}
async function loadPostStats(postId){
  const data=await api(`/api/posts/${postId}/summary`); if(!data) return;
  const el=document.getElementById('ps-stats-'+postId); if(!el) return;
  const {alarms,devices}=data;
  const online=devices.filter(d=>d.is_online).length;
  el.innerHTML=`<span class="post-stat ps-ok">◈ ${online}/${devices.length} онлайн</span>`+
    (alarms.critical?`<span class="post-stat ps-crit">⚠ ${alarms.critical} крит.</span>`:'')+
    (alarms.warning?`<span class="post-stat ps-warn">⚠ ${alarms.warning} попер.</span>`:
    !alarms.critical?`<span class="post-stat ps-ok">✓ Норма</span>`:'');
}
function selectPost(postId){
  document.querySelectorAll('.post-card').forEach(c=>c.classList.remove('selected'));
  document.getElementById('pc-'+postId)?.classList.add('selected');
  const marker=mapMarkers[postId];
  if(marker){leafMap.setView(marker.getLatLng(),12,{animate:true});marker.openPopup();}
}
function openPostModal(id,name,loc,region,lat,lng){
  editPostId=id||null;
  document.getElementById('post-modal-title').textContent=id?'Редагувати пост':'Новий пост';
  document.getElementById('pm-name').value=name||'';
  document.getElementById('pm-loc').value=loc||'';
  document.getElementById('pm-region').value=region||'';
  document.getElementById('pm-lat').value=lat||'';
  document.getElementById('pm-lng').value=lng||'';
  document.getElementById('post-modal').classList.add('open');
}
function closePostModal(){document.getElementById('post-modal').classList.remove('open');}
async function savePost(){
  const body={name:document.getElementById('pm-name').value.trim(),location:document.getElementById('pm-loc').value.trim(),region:document.getElementById('pm-region').value.trim(),latitude:parseFloat(document.getElementById('pm-lat').value)||null,longitude:parseFloat(document.getElementById('pm-lng').value)||null};
  if(!body.name){toast('Введіть назву','error');return;}
  const r=editPostId?await api('/api/posts/'+editPostId,'PATCH',body):await api('/api/posts/','POST',body);
  if(r?.ok){closePostModal();loadPosts();toast(editPostId?'Пост оновлено':'Пост створено','success');}
}
async function deletePost(id,name){
  if(!confirm(`Видалити пост "${name}"?`)) return;
  const r=await api('/api/posts/'+id,'DELETE');
  if(r?.ok){loadPosts();toast('Видалено','success');}
}

// ── DEVICE MODAL ─────────────────────────────────────────────
function openDevModal(postId,devId,type,name,host,port){
  editDevPostId=postId;
  document.getElementById('dev-modal-title').textContent=devId?'Редагувати прилад':'Новий прилад';
  document.getElementById('dm-type').value=type||'PAED_GAMMA';
  document.getElementById('dm-name').value=name||'';
  document.getElementById('dm-host').value=host||'';
  document.getElementById('dm-port').value=port||'';
  document.getElementById('device-modal').dataset.devId=devId||'';
  document.getElementById('device-modal').classList.add('open');
}
function closeDevModal(){document.getElementById('device-modal').classList.remove('open');}
async function saveDev(){
  const postId=editDevPostId, devId=document.getElementById('device-modal').dataset.devId;
  const body={type:document.getElementById('dm-type').value,name:document.getElementById('dm-name').value,host:document.getElementById('dm-host').value,port:parseInt(document.getElementById('dm-port').value)};
  if(!body.name||!body.host||!body.port){toast('Заповніть всі поля','error');return;}
  const r=devId?await api(`/api/posts/${postId}/devices/${devId}`,'PATCH',body):await api(`/api/posts/${postId}/devices`,'POST',body);
  if(r?.ok){closeDevModal();loadDevices();toast(devId?'Оновлено':'Додано','success');}
}
async function deleteDev(postId,devId,name){
  if(!confirm(`Видалити прилад "${name}"?`)) return;
  const r=await api(`/api/posts/${postId}/devices/${devId}`,'DELETE');
  if(r?.ok){loadDevices();toast('Видалено','success');}
}

// ── USERS ────────────────────────────────────────────────────
let allUsers=[], editUserId=null;

async function loadUsers(){
  const data=await api('/api/users/'); if(!data) return;
  allUsers=data; renderUsers(data);
}

function filterUsers(){
  const q=document.getElementById('users-search').value.toLowerCase();
  renderUsers(allUsers.filter(u=>!q||u.username.toLowerCase().includes(q)||u.email.toLowerCase().includes(q)));
}

function renderUsers(data){
  document.getElementById('users-tbody').innerHTML=data.map(u=>`<tr>
    <td class="val">${u.username}</td>
    <td>${u.email}</td>
    <td><span class="role-badge role-${u.role}">${u.role}</span></td>
    <td>${u.post_name||'—'}</td>
    <td style="font-family:var(--font-mono);font-size:11px">${u.last_login?fmt(u.last_login):'—'}</td>
    <td><span class="sb ${u.is_active?'s-RESOLVED':'s-IGNORED'}">${u.is_active?'Активний':'Заблокований'}</span></td>
    <td style="display:flex;gap:4px">
      ${u.id!==me.id?`
        <button class="btn-sm" onclick="openEditUser('${u.id}')">✎ Редагувати</button>
        <button class="btn-sm ${u.is_active?'red':''}" onclick="toggleUser('${u.id}',${!u.is_active})">
          ${u.is_active?'Блок':'Розблок'}
        </button>
        <button class="btn-sm red" onclick="deleteUser('${u.id}','${String(u.username).replace(/'/g, '&apos;')}')">🗑 Видалити</button>
      `:'<span style="font-size:11px;color:var(--text-dim)">це ви</span>'}
    </td>
  </tr>`).join('');
}

async function openUM(){
  editUserId=null;
  document.getElementById('um-title').textContent='Новий користувач';
  document.getElementById('um-pass-label').textContent='Пароль';
  document.getElementById('um-pass-group').style.display='';
  document.getElementById('nu').value='';
  document.getElementById('ne').value='';
  document.getElementById('np').value='';
  document.getElementById('nr').value='guest';
  document.getElementById('nu-post').value='';
  // Завантажуємо пости для вибору
  await loadPostsForSelect();
  document.getElementById('user-modal').classList.add('open');
}

async function openEditUser(userId){
  editUserId=userId;
  const u=allUsers.find(x=>x.id===userId); if(!u) return;
  document.getElementById('um-title').textContent=`Редагувати: ${u.username}`;
  document.getElementById('um-pass-label').textContent='Новий пароль (залиште порожнім щоб не змінювати)';
  document.getElementById('nu').value=u.username;
  document.getElementById('ne').value=u.email;
  document.getElementById('np').value='';
  document.getElementById('nr').value=u.role;
  await loadPostsForSelect(u.post_id);
  document.getElementById('user-modal').classList.add('open');
}

async function loadPostsForSelect(selectedPostId=null){
  const sel=document.getElementById('nu-post');
  sel.innerHTML='<option value="">— Всі пости (адмін/гість) —</option>';
  const posts=await api('/api/posts/');
  if(posts) posts.forEach(p=>{
    const opt=document.createElement('option');
    opt.value=p.id; opt.textContent=p.name;
    if(p.id===selectedPostId) opt.selected=true;
    sel.appendChild(opt);
  });
}

function closeUM(){
  document.getElementById('user-modal').classList.remove('open');
  editUserId=null;
}

async function saveUser(){
  const username=document.getElementById('nu').value.trim();
  const email=document.getElementById('ne').value.trim();
  const password=document.getElementById('np').value;
  const role=document.getElementById('nr').value;
  const post_id=document.getElementById('nu-post').value||null;

  if(!username||!email){toast('Заповніть логін та email','error');return;}

  if(editUserId){
    // Редагування
    const body={username,email,role,post_id:post_id||''};
    if(password){
      if(password.length<6){toast('Пароль мінімум 6 символів','error');return;}
      body.password=password;
    }
    const r=await api('/api/users/'+editUserId,'PATCH',body);
    if(r?.ok){closeUM();loadUsers();toast('Користувача оновлено','success');}
  } else {
    // Створення
    if(!password){toast('Введіть пароль','error');return;}
    if(password.length<6){toast('Пароль мінімум 6 символів','error');return;}
    const r=await api('/api/users/','POST',{username,email,password,role,post_id});
    if(r?.ok){closeUM();loadUsers();toast('Користувача створено','success');}
  }
}

async function toggleUser(id,active){
  await api('/api/users/'+id,'PATCH',{is_active:active});
  loadUsers();
  toast(active?'Розблоковано':'Заблоковано','success');
}

async function deleteUser(id,username){
  if(!confirm(`Видалити користувача "${username}"?\n\nКористувач буде прихований у веб-інтерфейсі, але запис залишиться в БД для синхронізації.`)) return;
  const r=await api('/api/users/'+id,'DELETE');
  if(r?.ok){
    await loadUsers();
    toast('Користувача видалено','success');
  }
}

// ── NAV ──────────────────────────────────────────────────────
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name)?.classList.add('active');
  document.getElementById('nav-'+name)?.classList.add('active');
  if(name==='alarms')  loadAlarms();
  if(name==='users')   loadUsers();
  if(name==='readings')renderReadings();
  if(name==='posts')   {loadPosts();setTimeout(()=>leafMap&&leafMap.invalidateSize(),300);}
}

// ── HELPERS ──────────────────────────────────────────────────
async function api(url,method='GET',body=null){
  try{
    const opts={method,headers:{Authorization:'Bearer '+token,'Content-Type':'application/json'}};
    if(body)opts.body=JSON.stringify(body);
    const r=await fetch(API+url,opts);
    if(r.status===401){doLogout();return null;}
    if(!r.ok){const err=await r.text();toast('Помилка '+r.status+': '+err.slice(0,80),'error');return null;}
    return await r.json();
  }catch(e){toast('Помилка мережі','error');return null;}
}
function fmt(iso){if(!iso)return'—';return new Date(iso).toLocaleString('uk-UA',{dateStyle:'short',timeStyle:'medium'});}
function ts(){return new Date().toISOString().replace(/[:.]/g,'-').slice(0,19);}
function dl(text,name,mime){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([text],{type:mime}));a.download=name;a.click();setTimeout(()=>URL.revokeObjectURL(a.href),1000);}
function toast(msg,type='success'){const el=document.createElement('div');el.className='toast '+type;el.textContent=msg;document.getElementById('toast-container').appendChild(el);setTimeout(()=>el.remove(),4000);}
</script>
