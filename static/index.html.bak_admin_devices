// ── PUSH АВАРІЯ (миттєво) ────────────────────────────────────
function handleAlarmPush(alarm){
  // Спливаюче сповіщення
  const isCrit=alarm.level==='CRITICAL';
  const el=document.createElement('div');
  el.className='toast-alarm'+(isCrit?'':' toast-warn');
  el.innerHTML=`<div class="toast-alarm-title">${isCrit?'🔴':'🟡'} ${alarm.level}: ${alarm.post_name||'—'}</div>
    <div class="toast-alarm-body">${alarm.message}<br/><span style="color:var(--text-dim)">${alarm.device_name||'—'} · ${fmt(alarm.triggered_at)}</span></div>`;
  document.getElementById('toast-container').appendChild(el);
  // Автозакриття: критичні 10с, інші 6с
  setTimeout(()=>el.remove(), isCrit?10000:6000);

  // Звуковий сигнал (якщо підтримується браузером)
  try{const ctx=new AudioContext();const o=ctx.createOscillator();const g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.frequency.value=isCrit?880:440;g.gain.setValueAtTime(.3,ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.5);
    o.start();o.stop(ctx.currentTime+.5);}catch{}
}

