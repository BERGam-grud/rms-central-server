<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>РМС — Радіаційний Моніторинг</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
:root{
  --bg-0:#0d0f12;--bg-1:#13161b;--bg-2:#1a1e26;--bg-3:#222730;
  --border:#2a2f3a;--border-hi:#3a4150;
  --text-pri:#e8ecf2;--text-sec:#8a94a6;--text-dim:#4a5568;
  --green:#00e5a0;--green-dim:#00724f;
  --yellow:#f0c040;--red:#ff4560;--blue:#4d9fff;--purple:#a78bfa;
  --font-mono:'Courier New',monospace;--font-ui:system-ui,-apple-system,sans-serif;
  --radius:6px;--tr:150ms ease;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg-0);color:var(--text-pri);font-family:var(--font-ui);font-size:14px;line-height:1.5;min-height:100vh;overflow-x:hidden}
button{cursor:pointer;border:none;background:none;font:inherit}
input,select,textarea{font:inherit}


/* SERVER SWITCH */
.server-switch{display:flex;gap:4px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);padding:3px}
.srv-btn{padding:4px 12px;border-radius:4px;font-size:11px;font-weight:600;color:var(--text-sec);transition:all var(--tr);letter-spacing:.04em}
.srv-btn.active{background:var(--bg-3);color:var(--green);border:1px solid var(--green-dim)}
.srv-btn:hover:not(.active){color:var(--text-pri)}
.central-banner{background:rgba(167,139,250,.08);border:1px solid rgba(167,139,250,.2);border-radius:var(--radius);padding:8px 14px;font-size:11px;color:var(--purple);display:none;align-items:center;gap:8px;margin-bottom:16px}
.central-banner.show{display:flex}

/* LOGIN */
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh}
.login-box{width:360px;padding:40px;background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius)}
.login-logo{display:flex;align-items:center;gap:12px;margin-bottom:32px}
.atom{width:40px;height:40px;border:2px solid var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;animation:spin 8s linear infinite}
.atom::before{content:'';width:8px;height:8px;background:var(--green);border-radius:50%}
@keyframes spin{to{transform:rotate(360deg)}}
.login-logo h1{font-size:18px;font-weight:700;letter-spacing:.05em}
.login-logo p{font-size:11px;color:var(--text-sec);letter-spacing:.1em;text-transform:uppercase}
.fg{margin-bottom:16px}
.fg label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-sec);margin-bottom:6px}
.fg input{width:100%;padding:10px 12px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-pri);transition:border-color var(--tr)}
.fg input:focus{outline:none;border-color:var(--green)}
.btn-primary{width:100%;padding:11px;background:var(--green);color:#000;font-weight:700;font-size:13px;border-radius:var(--radius);transition:opacity var(--tr);margin-top:8px}
.btn-primary:hover{opacity:.85}
.login-error{margin-top:12px;color:var(--red);font-size:12px;text-align:center;min-height:18px}

/* LAYOUT */
#app{display:none;height:100vh;flex-direction:column}
#app.visible{display:flex}
.topbar{height:52px;background:var(--bg-1);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:20px;flex-shrink:0;z-index:100}
.topbar-brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:13px;letter-spacing:.06em;text-transform:uppercase}
.dot{width:8px;height:8px;background:var(--green);border-radius:50%;box-shadow:0 0 8px var(--green);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 8px var(--green)}50%{opacity:.5;box-shadow:0 0 4px var(--green)}}
.topbar-time{margin-left:auto;font-family:var(--font-mono);font-size:12px;color:var(--text-sec)}
.topbar-user{display:flex;align-items:center;gap:8px;padding:5px 12px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);font-size:12px;color:var(--text-sec)}
.role-badge{padding:2px 7px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
.role-admin{background:rgba(167,139,250,.15);color:var(--purple)}
.role-operator{background:rgba(0,229,160,.12);color:var(--green)}
.role-guest{background:rgba(138,148,166,.15);color:var(--text-sec)}
.btn-logout{padding:4px 10px;border:1px solid var(--border);border-radius:var(--radius);color:var(--text-sec);font-size:11px;transition:all var(--tr)}
.btn-logout:hover{border-color:var(--red);color:var(--red)}
.main-body{display:flex;flex:1;overflow:hidden}

/* SIDEBAR */
.sidebar{width:220px;background:var(--bg-1);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;padding:16px 0}
.sidebar-section{padding:0 12px;margin-bottom:4px}
.sidebar-label{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--text-dim);padding:8px 8px 4px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--radius);color:var(--text-sec);font-size:13px;transition:all var(--tr);cursor:pointer;position:relative;margin-bottom:2px}
.nav-item:hover{background:var(--bg-2);color:var(--text-pri)}
.nav-item.active{background:rgba(0,229,160,.08);color:var(--green)}
.nav-item.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--green);border-radius:0 2px 2px 0}
.nav-icon{font-size:15px;width:20px;text-align:center}
.nav-badge{margin-left:auto;min-width:18px;height:18px;padding:0 5px;background:var(--red);color:#fff;font-size:10px;font-weight:700;border-radius:9px;display:flex;align-items:center;justify-content:center}
.sidebar-divider{height:1px;background:var(--border);margin:10px 12px}
.sidebar-status{margin-top:auto;padding:12px 20px;border-top:1px solid var(--border)}
.status-row{display:flex;justify-content:space-between;font-size:11px;color:var(--text-dim);margin-bottom:4px}
.status-val{color:var(--green);font-family:var(--font-mono)}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:24px;background:var(--bg-0)}
.page{display:none}
.page.active{display:block}
.page-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.page-title{font-size:22px;font-weight:700}
.page-sub{font-size:12px;color:var(--text-sec);margin-top:2px}
.page-actions{display:flex;gap:8px;flex-wrap:wrap}
.btn-action{padding:7px 14px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-sec);font-size:12px;transition:all var(--tr);display:flex;align-items:center;gap:6px}
.btn-action:hover{border-color:var(--border-hi);color:var(--text-pri)}
.btn-action.green{border-color:var(--green-dim);color:var(--green)}
.btn-action.green:hover{background:rgba(0,229,160,.08)}
.btn-action.red{border-color:#7a1f2e;color:var(--red)}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:12px;margin-bottom:24px}
.kpi-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:relative;overflow:hidden}
.kpi-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent,var(--border))}
.kpi-card.ga{--accent:var(--green)}.kpi-card.ya{--accent:var(--yellow)}.kpi-card.ra{--accent:var(--red)}.kpi-card.ba{--accent:var(--blue)}
.kpi-label{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--text-sec);margin-bottom:8px}
.kpi-value{font-family:var(--font-mono);font-size:26px;font-weight:700;line-height:1}
.kpi-unit{font-size:11px;color:var(--text-sec);margin-top:4px}

/* CHARTS */
.charts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(460px,1fr));gap:16px;margin-bottom:24px}
.chart-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.chart-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border)}
.chart-title{font-size:13px;font-weight:600}
.chart-meta{font-size:11px;color:var(--text-sec);margin-top:2px}
.chart-actions{display:flex;gap:6px}
.btn-export{padding:4px 10px;border:1px solid var(--border);border-radius:4px;color:var(--text-sec);font-size:11px;transition:all var(--tr)}
.btn-export:hover{border-color:var(--green-dim);color:var(--green)}
.chart-body{padding:16px;position:relative;height:220px}

/* ACTIVE ALARMS PANEL */
.alarm-panel{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:24px}
.alarm-panel-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border)}
.alarm-panel-title{font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.alarm-pulse{width:8px;height:8px;background:var(--red);border-radius:50%;box-shadow:0 0 6px var(--red);animation:pulse 1.5s ease-in-out infinite}
.alarm-rows{max-height:200px;overflow-y:auto}
.alarm-row{display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--border);transition:background var(--tr)}
.alarm-row:last-child{border-bottom:none}
.alarm-row:hover{background:var(--bg-2)}
.alarm-row-level{width:80px;flex-shrink:0}
.alarm-row-msg{flex:1;font-size:12px;color:var(--text-sec)}
.alarm-row-post{font-size:11px;color:var(--text-dim);white-space:nowrap}
.alarm-row-time{font-size:10px;font-family:var(--font-mono);color:var(--text-dim);white-space:nowrap}
.alarm-row-btn{flex-shrink:0}

/* TOAST ALARM */
.toast-alarm{padding:14px 16px;background:var(--bg-1);border:1px solid var(--red);border-left:4px solid var(--red);border-radius:var(--radius);font-size:13px;animation:slideIn .3s ease;max-width:360px;box-shadow:0 4px 20px rgba(255,69,96,.2)}
.toast-alarm-title{font-weight:700;color:var(--red);margin-bottom:4px}
.toast-alarm-body{font-size:12px;color:var(--text-sec)}
.toast-warn{border-color:var(--yellow);border-left-color:var(--yellow)}
.toast-warn .toast-alarm-title{color:var(--yellow)}

/* DEVICES */
.devices-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;margin-bottom:16px}
.device-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);padding:16px;transition:border-color var(--tr)}
.device-card:hover{border-color:var(--border-hi)}
.device-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.device-icon{width:36px;height:36px;background:var(--bg-3);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.device-name{font-size:13px;font-weight:600}
.device-type{font-size:11px;color:var(--text-sec)}
.device-conn{font-size:10px;color:var(--text-dim);font-family:var(--font-mono);margin-top:2px}
.online-dot{width:7px;height:7px;border-radius:50%;margin-left:auto;flex-shrink:0}
.online-dot.online{background:var(--green);box-shadow:0 0 6px var(--green)}
.online-dot.offline{background:var(--text-dim)}
.readings-list{display:flex;flex-direction:column;gap:6px}
.reading-row{display:flex;align-items:center;justify-content:space-between;padding:8px 10px;background:var(--bg-2);border-radius:4px;border-left:3px solid var(--green)}
.reading-row.warn{border-left-color:var(--yellow)}
.reading-row.crit{border-left-color:var(--red)}
.reading-param{font-size:11px;color:var(--text-sec);text-transform:uppercase;letter-spacing:.06em}
.reading-val{font-family:var(--font-mono);font-size:16px;font-weight:700}
.reading-unit{font-size:10px;color:var(--text-sec);margin-left:3px}
.reading-time{font-size:10px;color:var(--text-dim);margin-top:2px}
.device-footer{display:flex;gap:6px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}

/* THRESHOLDS */
.thresh-card{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);padding:12px;margin-top:10px}
.thresh-header{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-dim);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
.thresh-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:12px}
.thresh-param{color:var(--text-sec);width:90px;flex-shrink:0}
.thresh-val{font-family:var(--font-mono);font-size:11px}
.thresh-warn{color:var(--yellow)}
.thresh-crit{color:var(--red)}

/* TABLES */
.table-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.table-toolbar{display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:1px solid var(--border);flex-wrap:wrap}
.fi{padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-pri);font-size:12px}
.fi:focus{outline:none;border-color:var(--green)}
table{width:100%;border-collapse:collapse}
thead th{padding:10px 16px;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-dim);text-align:left;border-bottom:1px solid var(--border);background:var(--bg-1)}
tbody tr{border-bottom:1px solid var(--border);transition:background var(--tr)}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--bg-2)}
tbody td{padding:10px 16px;font-size:12px;color:var(--text-sec)}
tbody td.val{font-family:var(--font-mono);font-size:13px;color:var(--text-pri);font-weight:600}
.alv{display:inline-flex;align-items:center;gap:5px;padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700}
.lv-CRITICAL{background:rgba(255,69,96,.15);color:var(--red)}
.lv-WARNING{background:rgba(240,192,64,.15);color:var(--yellow)}
.lv-INFO{background:rgba(77,159,255,.15);color:var(--blue)}
.sb{padding:2px 7px;border-radius:3px;font-size:10px;font-weight:600}
.s-ACTIVE{background:rgba(255,69,96,.1);color:var(--red)}
.s-RESOLVED{background:rgba(0,229,160,.1);color:var(--green)}
.s-IGNORED{background:rgba(74,85,104,.3);color:var(--text-dim)}
.btn-sm{padding:3px 10px;border:1px solid var(--green-dim);border-radius:4px;color:var(--green);font-size:11px;transition:all var(--tr)}
.btn-sm:hover{background:rgba(0,229,160,.1)}
.btn-sm.red{border-color:#7a1f2e;color:var(--red)}
.btn-sm.red:hover{background:rgba(255,69,96,.08)}

/* POSTS */
.posts-layout{display:grid;grid-template-columns:1fr 340px;gap:16px;height:calc(100vh - 160px)}
.posts-map{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
#map{width:100%;height:100%;min-height:400px}
.posts-list{display:flex;flex-direction:column;gap:10px;overflow-y:auto;padding-right:4px}
.post-card{background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);padding:14px;cursor:pointer;transition:all var(--tr)}
.post-card:hover{border-color:var(--border-hi)}
.post-card.selected{border-color:var(--green);background:rgba(0,229,160,.04)}
.post-card-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.post-card-name{font-size:13px;font-weight:600;flex:1}
.post-card-meta{font-size:11px;color:var(--text-sec)}
.post-stats{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.post-stat{padding:3px 8px;border-radius:3px;font-size:11px;font-weight:600}
.ps-ok{background:rgba(0,229,160,.1);color:var(--green)}
.ps-warn{background:rgba(240,192,64,.1);color:var(--yellow)}
.ps-crit{background:rgba(255,69,96,.1);color:var(--red)}

/* ARCHIVE */
.filter-row{display:flex;flex-wrap:wrap;gap:10px;padding:16px;border-bottom:1px solid var(--border)}
.filter-row label{font-size:11px;color:var(--text-sec);display:flex;flex-direction:column;gap:4px}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{width:460px;background:var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;max-height:92vh;display:flex;flex-direction:column}
.modal-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-size:15px;font-weight:600;flex-shrink:0}
.modal-close{color:var(--text-sec);font-size:20px;cursor:pointer}
.modal-close:hover{color:var(--text-pri)}
.modal-body{padding:20px;display:flex;flex-direction:column;gap:14px;overflow-y:auto}
.modal-footer{padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;flex-shrink:0}
.modal-section{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text-dim);padding-bottom:6px;border-bottom:1px solid var(--border)}
.btn-cancel{padding:7px 16px;border:1px solid var(--border);border-radius:var(--radius);color:var(--text-sec);font-size:13px}
.btn-save{padding:7px 16px;background:var(--green);border-radius:var(--radius);color:#000;font-size:13px;font-weight:700}
.btn-save:hover{opacity:.85}
.btn-add{padding:7px 14px;background:rgba(0,229,160,.1);border:1px solid var(--green-dim);border-radius:var(--radius);color:var(--green);font-size:12px;font-weight:600;transition:all var(--tr)}
.btn-add:hover{background:rgba(0,229,160,.18)}

/* EMPTY/SPINNER */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;color:var(--text-dim);gap:8px}
.empty-state .icon{font-size:32px}
.empty-state p{font-size:13px}
.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite;margin:auto}

/* TOAST */
#toast-container{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;max-width:380px}
.toast{padding:10px 16px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);font-size:13px;animation:slideIn .2s ease}
.toast.success{border-left:3px solid var(--green)}
.toast.error{border-left:3px solid var(--red)}
@keyframes slideIn{from{transform:translateX(20px);opacity:0}to{transform:translateX(0);opacity:1}}

/* LEAFLET DARK */
.leaflet-container{background:#0d0f12!important}
.leaflet-tile{filter:invert(1) hue-rotate(180deg) brightness(.85) contrast(.9)}
.leaflet-popup-content-wrapper{background:var(--bg-1);border:1px solid var(--border);color:var(--text-pri);border-radius:var(--radius)}
.leaflet-popup-tip{background:var(--bg-1)}
.leaflet-popup-content{font-size:12px;line-height:1.6}

::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg-1)}
::-webkit-scrollbar-thumb{background:var(--bg-3);border-radius:3px}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo"><div class="atom"></div><div><h1>РМС</h1><p>Радіаційний моніторинг</p></div></div>
    <div class="fg"><label>Логін</label><input type="text" id="lu" placeholder="username" autocomplete="username"/></div>
    <div class="fg"><label>Пароль</label><input type="password" id="lp" placeholder="••••••••" autocomplete="current-password"/></div>
    <button class="btn-primary" onclick="doLogin()">Увійти</button>
    <div class="login-error" id="le"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-brand"><div class="dot"></div>РМС · Радіаційний моніторинг</div>
    <div class="server-switch" id="server-switch">
      <button class="srv-btn active" id="btn-local" onclick="switchServer('local')">
        ◉ Локальний
      </button>
      <button class="srv-btn" id="btn-central" onclick="switchServer('central')">
        ◎ Центральний
      </button>
    </div>
    <div class="topbar-time" id="tt">--:--:--</div>
    <div class="topbar-user">
      <span id="tu">—</span><span class="role-badge" id="tr2">—</span>
      <button class="btn-logout" onclick="doLogout()">Вийти</button>
    </div>
  </div>
  <div class="main-body">
    <nav class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Моніторинг</div>
        <div class="nav-item active" onclick="showPage('dashboard')" id="nav-dashboard"><span class="nav-icon">⬡</span>Головна</div>
