<div id="toast-container"></div>

<script>
// Автоматично визначаємо URL сервера
// Якщо відкрито з Railway — використовуємо відносні URL
// Якщо відкрито локально — localhost:8000
const IS_RAILWAY = window.location.hostname.includes('railway.app') ||
                   window.location.hostname.includes('ngrok');
const API_LOCAL   = IS_RAILWAY ? '' : 'http://localhost:8000';
const API_CENTRAL = 'https://rms-central-server-production.up.railway.app';
let API = API_LOCAL;
let currentServer = 'local';

// Якщо відкрито з Railway або ngrok — одразу використовуємо поточний сервер
if (IS_RAILWAY) {
  API = '';  // відносні URL — запити йдуть на той самий сервер
}

function switchServer(type) {
  currentServer = type;
  if (type === 'central') {
    API = API_CENTRAL;
  } else {
    // Локальний: якщо ми на Railway — відносні URL, інакше localhost
    API = IS_RAILWAY ? '' : 'http://localhost:8000';
  }

  // Оновлюємо кнопки
  document.getElementById('btn-local').classList.toggle('active', type==='local');
  document.getElementById('btn-central').classList.toggle('active', type==='central');

  // Банер
  const banner = document.getElementById('central-banner');
  if (banner) banner.classList.toggle('show', type==='central');

  // Перепідключаємо WebSocket
  if (ws) { ws.close(); }

  // Очищаємо графіки
  chartHist = {};
  for (const p of CH_PARAMS) {
    if (chartInst[p]) {
      chartInst[p].data.labels = [];
      chartInst[p].data.datasets[0].data = [];
      chartInst[p].update('none');
    }
  }

  // Перезавантажуємо дані
  loadDevices();
  loadAlarms();
  initCharts();
  toast(type==='central' ? '◎ Центральний сервер' : '◉ Локальний сервер', 'success');
}
let token=localStorage.getItem('rms_token')||null;
let me=JSON.parse(localStorage.getItem('rms_user')||'null');
let ws=null, wsRetry=0;
let liveData=[],liveAlarms={},activeAlarms=[];
let chartInst={},chartHist={};
let readingsData=[],alarmsData=[],archData=[];
let allPosts=[],editPostId=null,editDevPostId=null;
let leafMap=null,mapMarkers={};
let threshEditId=null,threshDevType=null,threshPostId=null,threshDeviceId=null;
const MAX_PTS=200;
const CH_PARAMS=['dose_rate','activity','flow_rate'];
const CH_LABELS={dose_rate:'Доза гамма (мкЗв/год)',activity:'Активність (Бк/м³)',flow_rate:'Витрата повітря (м³/год)'};
const CH_COLORS={dose_rate:'#00e5a0',activity:'#f0c040',flow_rate:'#4d9fff'};
const KPI_LABELS={dose_rate:'Доза гамма',activity:'Активність',flow_rate:'Витрата повітря',filter_load:'Завантаж. фільтра',peak_energy:'Пік енергії'};
const KPI_ACC={dose_rate:'ga',activity:'ya',flow_rate:'ba',filter_load:'ba',peak_energy:'ga'};

// ── INIT ────────────────────────────────────────────────────
window.addEventListener('load',()=>{
  if(token&&me)boot(); else showLogin();
  setInterval(clock,1000); clock();
});
function clock(){
  const n=new Date(),p=x=>String(x).padStart(2,'0');
  document.getElementById('tt').textContent=`${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}  ${n.toLocaleDateString('uk-UA')}`;
}

// ── AUTH ────────────────────────────────────────────────────
function showLogin(){document.getElementById('login-screen').style.display='flex';document.getElementById('app').classList.remove('visible');}
async function doLogin(){
  const u=document.getElementById('lu').value.trim(),p=document.getElementById('lp').value;
  document.getElementById('le').textContent='';
  const fd=new FormData(); fd.append('username',u); fd.append('password',p);
  try{
    const r=await fetch(`${API}/api/auth/login`,{method:'POST',body:fd});
    if(!r.ok){document.getElementById('le').textContent='Невірний логін або пароль';return;}
    const d=await r.json(); token=d.access_token; me=d.user;
    localStorage.setItem('rms_token',token); localStorage.setItem('rms_user',JSON.stringify(me));
    boot();
  }catch{document.getElementById('le').textContent='Помилка підключення';}
}
document.addEventListener('keydown',e=>{if(e.key==='Enter'&&document.getElementById('login-screen').style.display!=='none')doLogin();});
function doLogout(){
  token=null; me=null;
  localStorage.removeItem('rms_token'); localStorage.removeItem('rms_user');
  if(ws)ws.close();
  document.getElementById('app').classList.remove('visible');
  document.getElementById('login-screen').style.display='flex';
}

// ── BOOT ────────────────────────────────────────────────────
function boot(){
  document.getElementById('login-screen').style.display='none';
  document.getElementById('app').classList.add('visible');
  document.getElementById('tu').textContent=me.username;
  const b=document.getElementById('tr2'); b.textContent=me.role; b.className='role-badge role-'+me.role;
  if(me.role!=='admin') document.getElementById('admin-section').style.display='none';
  connectWS();
  loadDevices();
  initCharts();
  showPage('dashboard');
}

// ── WEBSOCKET ───────────────────────────────────────────────
function connectWS(){
  let wsUrl;
  if (IS_RAILWAY && currentServer === 'local') {
    // На Railway — використовуємо поточний хост
    const proto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    wsUrl = proto + '//' + window.location.host + '/ws/live';
  } else {
    wsUrl = API.replace('https://', 'wss://').replace('http://', 'ws://') + '/ws/live';
  }
  ws=new WebSocket(wsUrl);
  ws.onopen=()=>{
    wsRetry=0;
    document.getElementById('ws-status').textContent='●  онлайн';
    document.getElementById('ws-status').style.color='var(--green)';
  };
  ws.onmessage=e=>{
    const d=JSON.parse(e.data);
    if(d.type==='alarm') handleAlarmPush(d.alarm);
    else handleLive(d);
  };
  ws.onclose=()=>{
    document.getElementById('ws-status').textContent='○  офлайн';
    document.getElementById('ws-status').style.color='var(--red)';
    const delay=Math.min(30000, 3000*Math.pow(1.5,wsRetry++));
    setTimeout(connectWS, delay);
  };
}

// ── LIVE DATA ────────────────────────────────────────────────
function handleLive(d){
  liveData=d.measurements||[];
  liveAlarms=d.alarms||{};
  activeAlarms=d.active_alarms||[];

  // Бейдж аварій у сайдбарі
  const tot=Object.values(liveAlarms).reduce((s,v)=>s+v,0);
  const b=document.getElementById('alarm-badge');
  if(tot>0){b.style.display='flex';b.textContent=tot;}else b.style.display='none';
  document.getElementById('stat-alarms').textContent=tot||'0';
  document.getElementById('dash-upd').textContent='Оновлено: '+new Date().toLocaleTimeString('uk-UA');

  updateKPI();
  updateChartLive();
  updateDevCards();
  renderAlarmPanel();
  if(document.getElementById('page-readings').classList.contains('active')) renderReadings();

  // Оновлення сторінки аварій якщо відкрита
  if(document.getElementById('page-alarms').classList.contains('active')){
    renderAlarmsTable(activeAlarms);
