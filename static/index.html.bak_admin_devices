// ── CHARTS: live оновлення ───────────────────────────────────
function updateChartLive(){
  const now=new Date();
  for(const r of liveData){
    if(!CH_PARAMS.includes(r.parameter)) continue;
    const k=r.device_id+'::'+r.parameter;
    if(!chartHist[k]) chartHist[k]=[];
    // Додаємо тільки якщо нові дані
    const last=chartHist[k][chartHist[k].length-1];
    if(last && Math.abs(now-last.t)<2000) continue;
    chartHist[k].push({t:now,v:parseFloat(r.value)});
    if(chartHist[k].length>MAX_PTS) chartHist[k].shift();
  }
  for(const p of CH_PARAMS){
    const ch=chartInst[p]; if(!ch) continue;
    const k=Object.keys(chartHist).find(x=>x.endsWith('::'+p)); if(!k) continue;
    const h=chartHist[k];
    ch.data.labels=h.map(x=>x.t.toLocaleTimeString('uk-UA'));
    ch.data.datasets[0].data=h.map(x=>x.v);
    ch.update('none');
    const meta=document.getElementById('chart-meta-'+p);
    if(meta) meta.textContent=`Реальний час · ${h.length} точок`;
  }
}

// ── CHART EXPORT ─────────────────────────────────────────────
function expPNG(p){const a=document.createElement('a');a.href=document.getElementById('ch-'+p).toDataURL('image/png');a.download=p+'_'+ts()+'.png';a.click();toast('Збережено PNG','success');}
function expCSV(p){const k=Object.keys(chartHist).find(x=>x.endsWith('::'+p));if(!k)return;dl('Час,Значення\n'+chartHist[k].map(x=>`${x.t.toISOString()},${x.v}`).join('\n'),p+'_'+ts()+'.csv','text/csv');toast('Збережено CSV','success');}
function expSVG(p){
  const k=Object.keys(chartHist).find(x=>x.endsWith('::'+p));if(!k)return;
  const h=chartHist[k],W=600,H=200,PL=50,PR=10,PT=10,PB=30,W2=W-PL-PR,H2=H-PT-PB;
  const vals=h.map(x=>x.v),mn=Math.min(...vals),mx=Math.max(...vals)||mn+1;
  const px=i=>PL+(i/(h.length-1||1))*W2,py=v=>PT+H2-((v-mn)/(mx-mn))*H2;
  const pts=h.map((x,i)=>`${px(i)},${py(x.v)}`).join(' ');
  const fp=`${px(0)},${PT+H2} ${pts} ${px(h.length-1)},${PT+H2}`;
  const c=CH_COLORS[p];
  dl(`<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" style="background:#13161b">
    <polygon points="${fp}" fill="${c}18"/>
    <polyline points="${pts}" fill="none" stroke="${c}" stroke-width="1.5"/>
    <text x="${PL}" y="${H-6}" fill="#4a5568" font-size="10">${h[0]?.t.toLocaleTimeString('uk-UA')||''}</text>
    <text x="${W-PR}" y="${H-6}" fill="#4a5568" font-size="10" text-anchor="end">${h[h.length-1]?.t.toLocaleTimeString('uk-UA')||''}</text>
    <text x="${W/2}" y="18" fill="#e8ecf2" font-size="11" text-anchor="middle">${CH_LABELS[p]}</text></svg>`,
    p+'_'+ts()+'.svg','image/svg+xml');
  toast('Збережено SVG','success');
}

