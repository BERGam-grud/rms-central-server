  document.getElementById('tm-crit').value=crit||'';
  document.getElementById('thresh-modal').classList.add('open');
}
function closeThreshModal(){document.getElementById('thresh-modal').classList.remove('open');}
async function saveThresh(){
  const body={device_type:threshDevType,device_id:threshDeviceId,post_id:threshPostId,
    parameter:document.getElementById('tm-param').value.trim(),
    unit:document.getElementById('tm-unit').value.trim(),
    warn_value:parseFloat(document.getElementById('tm-warn').value),
    crit_value:parseFloat(document.getElementById('tm-crit').value)};
  if(!body.parameter||isNaN(body.warn_value)||isNaN(body.crit_value)){toast('Заповніть всі поля','error');return;}
  if(body.warn_value>=body.crit_value){toast('Критичне має бути більше за попереджувальне','error');return;}
  let r;
  if(threshEditId) r=await api('/api/thresholds/'+threshEditId,'PATCH',body);
  else r=await api('/api/thresholds/','POST',body);
  if(r?.ok){closeThreshModal();loadDevices();toast(threshEditId?'Поріг оновлено':'Поріг створено','success');}
}
async function deleteThresh(id){
  if(!confirm('Видалити поріг?')) return;
  const r=await api('/api/thresholds/'+id,'DELETE');
